@model AppCompleta.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = Configuracion.NameTittle;
}

<div class="flex items-center justify-center min-h-[60vh] px-4">
    <div class="w-full max-w-md bg-[#1e293b] border border-slate-700 rounded-sm p-8 shadow-2xl">

        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-white tracking-tight">Registrar Nuevo Usuario</h1>
            <p class="text-xs text-slate-400 mt-1">Acceso administrativo oculto</p>
        </div>

        <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-5">

            <div asp-validation-summary="All"class="[&.validation-summary-valid]:hidden bg-rose-950/30 border border-rose-900/50 p-4 rounded-sm text-rose-400 text-sm  [&_ul]:pl-5 [&_ul]:space-y-1 [&_li]:font-semibold mb-6"> </div>

            <div>
                <label for="Nombre" class="block text-sm font-medium text-slate-300 mb-1.5">Nombre Completo</label>
                <input asp-for="Nombre" type="text" required
                       class="w-full bg-[#0f172a] border border-slate-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:border-slate-500 focus:ring-1 focus:ring-slate-500 outline-none transition-all shadow-inner"
                       placeholder="Jesus Pablo" />
            </div>

            <div>
                <label for="Correo" class="block text-sm font-medium text-slate-300 mb-1.5">Correo Electrónico</label>
                <input asp-for="Correo" type="email" required
                       class="w-full bg-[#0f172a] border border-slate-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:border-slate-500 focus:ring-1 focus:ring-slate-500 outline-none transition-all shadow-inner"
                       placeholder="usuario@gmail.com" />
            </div>

            <div>
                <label for="Clave" class="block text-sm font-medium text-slate-300 mb-1.5">Contraseña</label>
                <input asp-for="Clave" type="password" required
                       class="w-full bg-[#0f172a] border border-slate-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:border-slate-500 focus:ring-1 focus:ring-slate-500 outline-none transition-all shadow-inner"
                       placeholder="••••••••" />
            </div>

            <div class="pt-2">
                <button type="submit" class="w-full flex justify-center py-2.5 px-4 bg-white text-slate-900 text-sm font-bold rounded-sm shadow-sm hover:bg-slate-200 transition-colors">
                    Crear Usuario
                </button>
            </div>

        </form>

        <div class="mt-6 text-center text-sm text-slate-400 border-t border-slate-700/50 pt-6">
            ¿Ya tienes cuenta?
            <a asp-controller="Auth" asp-action="Index" class="font-bold text-white hover:text-slate-300 transition-colors">
                Volver a Iniciar Sesión
            </a>
        </div>

    </div>
</div>
