@model AppCompleta.ViewModels.LoginViewModel
@{
    ViewData["Title"] = Configuracion.NameTittle;
    string exito = (string)TempData["Exito"]!;
    string error = (string)TempData["Error"]!;
}

<div class="flex items-center justify-center min-h-[60vh] px-4">
    
    <div class="w-full max-w-md bg-[#1e293b] border border-slate-700 rounded-sm p-8 shadow-2xl">
        @HelpMe.Mostrar(exito, error)
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-white tracking-tight">Ingresar Sesion</h1>
        </div>

        <form asp-controller="Auth" asp-action="Index" method="post" class="space-y-5" id="loginForm" onsubmit="showLoading()">

            <div asp-validation-summary="All" class="[&.validation-summary-valid]:hidden bg-rose-950/30 border border-rose-900/50 p-4 rounded-sm text-rose-400 text-sm  [&_ul]:pl-5 [&_ul]:space-y-1 [&_li]:font-semibold mb-6"> </div>

            <div>
                <label for="Email" class="block text-sm font-medium text-slate-300 mb-1.5">Correo Electrónico</label>
                <input asp-for="Correo" type="email" required
                       class="w-full bg-[#0f172a] border border-slate-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:border-slate-500 focus:ring-1 focus:ring-slate-500 outline-none transition-all shadow-inner"
                       placeholder="usuario@gmail.com"  value="pazjesu17@gmail.com"/>
            </div>

            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <label for="Password" class="block text-sm font-medium text-slate-300">Contraseña</label>
                </div>
                <input asp-for="Clave" type="password" required
                       class="w-full bg-[#0f172a] border border-slate-700 rounded-sm px-4 py-2.5 text-sm text-white placeholder-slate-500 focus:border-slate-500 focus:ring-1 focus:ring-slate-500 outline-none transition-all shadow-inner"
                       placeholder="••••••••" value="11111111"/>
            </div>

            <div class="flex items-center">
            </div>

            <div class="pt-2">
                <button type="submit" id="btnSubmit" class="w-full flex items-center justify-center py-2.5 px-4 bg-white text-slate-900 text-sm font-bold rounded-sm shadow-sm hover:bg-slate-200 transition-colors">
                    <span id="btnText">Iniciar Sesión</span>
                    <svg id="btnSpinner" class="hidden animate-spin ml-2 h-4 w-4 text-slate-900" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>

        </form>

        <script>
            function showLoading() {
                const btn = document.getElementById('btnSubmit');
                const btnText = document.getElementById('btnText');
                const btnSpinner = document.getElementById('btnSpinner');
                
                // Deshabilitar botón
                btn.disabled = true;
                btn.classList.add('opacity-80', 'cursor-wait');
                
                // Cambiar texto y mostrar spinner
                btnText.innerText = 'Cargando...';
                btnSpinner.classList.remove('hidden');
            }
        </script>

       @*  <div class="mt-6 text-center text-sm text-slate-400 border-t border-slate-700/50 pt-6">
            ¿No tienes una cuenta?
            <a asp-controller="" asp-action="" class="font-bold text-white hover:text-slate-300 transition-colors">
                Solicitar acceso
            </a>
        </div> *@

    </div>
</div>