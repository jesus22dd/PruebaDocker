@{
    string placeholder = ViewData["SearchPlaceholder"] as string ?? "Buscar...";
}

<div class="p-4 bg-slate-50 border-b border-slate-200">
    <form asp-action="Index" method="get" class="flex flex-col sm:flex-row gap-4 items-end">
        <!-- Buscador: Ocupa todo el espacio disponible -->
        <div class="flex-grow w-full">
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Buscar</label>
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" placeholder="@placeholder" class="w-full px-3 py-2 bg-white border border-slate-300 rounded-sm text-sm focus:outline-none focus:border-slate-500">
        </div>
        
        <!-- CONTENEDOR PARA MANTENER SELECT Y BOTONES EN LA MISMA LÍNEA EN MÓVIL -->
        <div class="flex flex-row gap-4 items-end">
            <!-- Ordenar: Ancho fijo y simétrico -->
            <div class="flex-none" style="width: 180px;">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Ordenar por</label>
                <select name="sortOrder" style="height: 38px;" class="w-full px-3 bg-white border border-slate-300 rounded-sm text-sm focus:outline-none focus:border-slate-500">
                    @if (ViewData["CurrentSort"] as string == "antiguo") {
                        <option value="reciente">Más recientes</option>
                        <option value="antiguo" selected>Más antiguos</option>
                    } else {
                        <option value="reciente" selected>Más recientes</option>
                        <option value="antiguo">Más antiguos</option>
                    }
                </select>
            </div>
            
            <!-- Botones -->
            <div class="flex-none flex flex-col">
                <label class="block text-xs font-bold uppercase tracking-wider mb-1 opacity-0 pointer-events-none select-none">Oculto</label>
                <div class="flex gap-2">
                    <button type="submit" style="height: 38px;" class="px-5 bg-slate-800 text-white text-xs font-bold uppercase rounded-sm hover:bg-slate-700 transition-colors shadow-sm whitespace-nowrap">
                        Filtrar
                    </button>
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                    {
                        <a asp-action="Index" style="height: 38px;" class="px-5 bg-white border border-slate-300 text-slate-700 text-xs font-bold uppercase rounded-sm hover:bg-slate-50 transition-colors shadow-sm whitespace-nowrap flex items-center justify-center">
                            Limpiar
                        </a>
                    }
                </div>
            </div>
        </div>
    </form>
</div>
