@model AppCompleta.Helpers.IPaginatedList

@if (Model != null && Model.TotalPages > 0)
{
    <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="text-sm text-slate-500">
            Página <span class="font-bold text-slate-700">@Model.PageIndex</span> de <span class="font-bold text-slate-700">@Model.TotalPages</span> 
            (Total: @Model.TotalCount registros)
        </div>
        
        <div class="flex gap-1">
            @{
                string prevDisabled = !Model.HasPreviousPage ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-slate-200";
                string nextDisabled = !Model.HasNextPage ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-slate-200";
            }
            
            <a asp-action="Index"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-pageNumber="@(Model.PageIndex - 1)"
               asp-route-searchString="@ViewData["CurrentFilter"]"
               class="px-3 py-1.5 border border-slate-300 rounded-sm text-sm font-medium text-slate-700 bg-white transition-colors shadow-sm @prevDisabled">
                Anterior
            </a>

            <!-- Lógica de acortamiento de páginas (Ej: 1 2 3 ... 140) -->
            @{
                int startPage = Math.Max(1, Model.PageIndex - 2);
                int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                
                if (startPage > 1)
                {
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="1" asp-route-searchString="@ViewData["CurrentFilter"]" class="px-3 py-1.5 border border-slate-300 rounded-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-200 transition-colors shadow-sm">1</a>
                    if (startPage > 2)
                    {
                        <span class="px-3 py-1.5 text-slate-400 font-bold">...</span>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    if (i == Model.PageIndex)
                    {
                        <span class="px-3 py-1.5 border border-[#0f172a] rounded-sm text-sm font-bold text-white bg-[#0f172a] shadow-sm">@i</span>
                    }
                    else
                    {
                        <a asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@i" asp-route-searchString="@ViewData["CurrentFilter"]" class="px-3 py-1.5 border border-slate-300 rounded-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-200 transition-colors shadow-sm">@i</a>
                    }
                }

                if (endPage < Model.TotalPages)
                {
                    if (endPage < Model.TotalPages - 1)
                    {
                        <span class="px-3 py-1.5 text-slate-400 font-bold">...</span>
                    }
                    <a asp-action="Index" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@Model.TotalPages" asp-route-searchString="@ViewData["CurrentFilter"]" class="px-3 py-1.5 border border-slate-300 rounded-sm text-sm font-medium text-slate-700 bg-white hover:bg-slate-200 transition-colors shadow-sm">@Model.TotalPages</a>
                }
            }

            <a asp-action="Index"
               asp-route-sortOrder="@ViewData["CurrentSort"]"
               asp-route-pageNumber="@(Model.PageIndex + 1)"
               asp-route-searchString="@ViewData["CurrentFilter"]"
               class="px-3 py-1.5 border border-slate-300 rounded-sm text-sm font-medium text-slate-700 bg-white transition-colors shadow-sm @nextDisabled">
                Siguiente
            </a>
        </div>
    </div>
}
