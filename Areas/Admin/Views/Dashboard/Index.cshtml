@model AppCompleta.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Administrativo";
}

<div class="mt-6 space-y-6">
    <!-- 1. Tarjetas Superiores (KPIs) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Ingresos Totales -->
        <!-- Ingresos del Mes -->
        <div class="bg-white rounded-xl shadow border border-slate-200 p-4 sm:p-6 flex items-center gap-6 hover:shadow-lg transition-shadow">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: conic-gradient(#10b981 75%, #f1f5f9 0); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center;">
                    <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </div>
            <div>
                <span class="text-2xl sm:text-3xl font-extrabold text-[#0f172a] block">@Model.IngresosTotales.ToString("C")</span>
                <h3 class="text-[10px] sm:text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Ingresos Totales Históricos</h3>
            </div>
        </div>

        <!-- Total Ventas -->
        <div class="bg-white rounded-xl shadow border border-slate-200 p-4 sm:p-6 flex items-center gap-6 hover:shadow-lg transition-shadow">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: conic-gradient(#3b82f6 60%, #f1f5f9 0); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center;">
                    <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
            </div>
            <div>
                <span class="text-2xl sm:text-3xl font-extrabold text-[#0f172a] block">@Model.TotalVentas</span>
                <h3 class="text-[10px] sm:text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Total Ventas Históricas</h3>
            </div>
        </div>

        <!-- Clientes -->
        <div class="bg-white rounded-xl shadow border border-slate-200 p-4 sm:p-6 flex items-center gap-6 hover:shadow-lg transition-shadow">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: conic-gradient(#a855f7 45%, #f1f5f9 0); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center;">
                    <svg class="w-8 h-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
            </div>
            <div>
                <span class="text-2xl sm:text-3xl font-extrabold text-[#0f172a] block">@Model.TotalClientes</span>
                <h3 class="text-[10px] sm:text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Clientes Registrados</h3>
            </div>
        </div>

        <!-- Alerta Inventario -->
        <div class="bg-white rounded-xl shadow border border-slate-200 p-4 sm:p-6 flex items-center gap-6 hover:shadow-lg transition-shadow">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: conic-gradient(#f43f5e 25%, #f1f5f9 0); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <div style="width: 64px; height: 64px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center;">
                    <span class="text-2xl font-black text-rose-500">@Model.AlertasStock</span>
                </div>
            </div>
            <div>
                <span class="text-lg sm:text-xl font-extrabold text-[#0f172a] block">Productos bajos</span>
                <h3 class="text-[10px] sm:text-xs font-bold text-slate-500 uppercase tracking-wider mt-1">Alertas de Stock</h3>
            </div>
        </div>
    </div>

    <!-- 2. Gráficos Secundarios (Dona y Barras, AHORA ARRIBA) -->
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem;">
        <!-- Gráfico de Dona (Categorías) -->
        <div class="bg-white rounded-sm shadow-md border border-slate-300 overflow-hidden" style="flex: 1 1 45%; min-width: 300px;">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">Top 5 Categorías</h3>
            </div>
            <div class="p-6 relative w-full flex items-center justify-center" style="height: 300px;">
                @if (Model.NombresCategorias.Count > 0)
                {
                    <canvas id="donutChart"></canvas>
                }
                else
                {
                    <p class="text-slate-400 text-sm">No hay datos suficientes</p>
                }
            </div>
        </div>

        <!-- Gráfico de Barras Horizontales (Top Clientes) -->
        <div class="bg-white rounded-sm shadow-md border border-slate-300 overflow-hidden" style="flex: 1 1 45%; min-width: 300px;">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">Top 5 Clientes (Histórico)</h3>
            </div>
            <div class="p-6 relative w-full flex items-center justify-center" style="height: 300px;">
                @if (Model.NombresMejoresClientes.Count > 0)
                {
                    <canvas id="barChart"></canvas>
                }
                else
                {
                    <p class="text-slate-400 text-sm">No hay datos suficientes</p>
                }
            </div>
        </div>
    </div>

    <!-- 2.75 Gráficos Avanzados (Polar y Tendencia) -->
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 1.5rem;">
        <!-- Gráfico de Área Polar (Capital) -->
        <div class="bg-white rounded-sm shadow-md border border-slate-300 overflow-hidden" style="flex: 1 1 45%; min-width: 300px;">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">Distribución de Capital en Inventario</h3>
            </div>
            <div class="p-6 relative w-full flex items-center justify-center" style="height: 300px;">
                @if (Model.NombresCapital.Count > 0)
                {
                    <canvas id="polarChart"></canvas>
                }
                else
                {
                    <p class="text-slate-400 text-sm">No hay datos suficientes</p>
                }
            </div>
        </div>

        <!-- Gráfico de Evolución de Ingresos (Barras Verticales) -->
        <div class="bg-white rounded-sm shadow-md border border-slate-300 overflow-hidden" style="flex: 1 1 45%; min-width: 300px;">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h3 class="text-sm font-bold text-white uppercase tracking-wider">Evolución de Ingresos (Últimos 7 Días)</h3>
            </div>
            <div class="p-6 relative w-full flex items-center justify-center" style="height: 300px;">
                <canvas id="areaChart"></canvas>
            </div>
        </div>
    </div>
    </div>
    
    <!-- 3. Tablas Rápidas y Gráfico Medio -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Top Productos -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h2 class="text-sm font-bold text-white uppercase tracking-wider">Top 5 Productos Más Vendidos</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-100 text-xs text-slate-700 uppercase tracking-wider border-b-2 border-slate-300">
                            <th class="px-6 py-3 font-bold">Producto</th>
                            <th class="px-6 py-3 font-bold text-center">Unidades</th>
                            <th class="px-6 py-3 font-bold text-right">Ingresos</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm text-slate-800 divide-y divide-slate-200">
                        @foreach (var p in Model.TopProductos)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-3 font-semibold text-[#0f172a]">@p.Nombre</td>
                                <td class="px-6 py-3 text-center">
                                    <span class="px-2 py-1 text-xs font-bold bg-blue-100 text-blue-800 rounded-sm">@p.CantidadVendida</span>
                                </td>
                                <td class="px-6 py-3 text-right font-mono text-emerald-600 font-bold">@p.IngresosGenerados.ToString("C")</td>
                            </tr>
                        }
                        @if(!Model.TopProductos.Any()) {
                            <tr><td colspan="3" class="px-6 py-4 text-center text-slate-400">Sin datos registrados</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Ticket Promedio (En medio) -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h2 class="text-sm font-bold text-white uppercase tracking-wider">Ticket Promedio (7 días)</h2>
            </div>
            <div class="p-6 relative w-full flex items-center justify-center" style="height: 350px;">
                @if (Model.FechasTicket.Count > 0)
                {
                    <canvas id="trendChart"></canvas>
                }
                else
                {
                    <p class="text-slate-400 text-sm">No hay datos suficientes</p>
                }
            </div>
        </div>

        <!-- Alerta Inventario -->
        <div class="bg-white border border-slate-300 rounded-sm shadow-md overflow-hidden">
            <div class="px-6 py-4 bg-[#0f172a] border-b border-[#0f172a]">
                <h2 class="text-sm font-bold text-white uppercase tracking-wider">Atención de Inventario</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-100 text-xs text-slate-700 uppercase tracking-wider border-b-2 border-slate-300">
                            <th class="px-6 py-3 font-bold">Producto</th>
                            <th class="px-6 py-3 font-bold">Categoría</th>
                            <th class="px-6 py-3 font-bold text-right">Stock</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm text-slate-800 divide-y divide-slate-200">
                        @foreach (var p in Model.ProductosStockBajo)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-3 font-semibold text-[#0f172a]">@p.Nombre</td>
                                <td class="px-6 py-3 text-slate-500">@p.IdCategoriaNavigation.Nombre</td>
                                <td class="px-6 py-3 text-right">
                                    <span class="px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider bg-rose-100 text-rose-800 border border-rose-300 rounded-sm">@p.Stock</span>
                                </td>
                            </tr>
                        }
                        @if(!Model.ProductosStockBajo.Any()) {
                            <tr><td colspan="3" class="px-6 py-4 text-center text-slate-400">Todo el inventario está en orden</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js via CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
            // Datos Inyectados desde el Modelo
            const areaFechas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FechasIngresos));
            const areaValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresIngresos));
            
            const donutCategorias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NombresCategorias));
            const donutValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresCategorias));

            const barClientes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NombresMejoresClientes));
            const barValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresMejoresClientes));

            const polarCategorias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NombresCapital));
            const polarValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresCapital));

            const trendFechas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FechasTicket));
            const trendValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresTicket));

            // Configuración Global de Chart.js
            Chart.defaults.font.family = "'Inter', 'Segoe UI', Roboto, sans-serif";
            Chart.defaults.color = '#64748b'; // slate-500
            
            // 1. Gráfico de Área (Evolución de Ingresos)
            const ctxArea = document.getElementById('areaChart');
            if (ctxArea) {
                // Crear gradiente vibrante
                const gradientArea = ctxArea.getContext('2d').createLinearGradient(0, 0, 0, 400);
                gradientArea.addColorStop(0, 'rgba(59, 130, 246, 0.5)'); // Azul semitransparente
                gradientArea.addColorStop(1, 'rgba(59, 130, 246, 0.0)'); // Desvanecido

                new Chart(ctxArea, {
                    type: 'bar',
                    data: {
                        labels: areaFechas,
                        datasets: [{
                            label: 'Ingresos',
                            data: areaValores,
                            backgroundColor: '#3b82f6', // blue-500
                            borderRadius: 6, // Puntas redondeadas
                            barThickness: 30, // Barras estéticas
                            hoverBackgroundColor: '#2563eb'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        layout: {
                            padding: {
                                left: 10,
                                right: 10,
                                top: 20,
                                bottom: 10
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                titleFont: { size: 13 },
                                bodyFont: { size: 14, weight: 'bold' },
                                padding: 12,
                                displayColors: false,
                                callbacks: {
                                    label: function(context) {
                                        let value = context.parsed.y;
                                        return new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB' }).format(value);
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grace: '30%', // Da un respiro del 30% arriba para que la curva no choque con el techo
                                grid: { color: '#e2e8f0', drawBorder: false },
                                ticks: {
                                    padding: 15, // Más separación de la línea
                                    maxTicksLimit: 6,
                                    callback: function(value) {
                                        return 'Bs ' + value.toLocaleString('es-BO');
                                    }
                                }
                            },
                            x: {
                                grid: { display: false, drawBorder: false },
                                ticks: {
                                    padding: 10
                                }
                            }
                        }
                    }
                });
            }

            const ctxDonut = document.getElementById('donutChart');
            if (ctxDonut) {
                new Chart(ctxDonut, {
                    type: 'pie',
                    data: {
                        labels: donutCategorias,
                        datasets: [{
                            data: donutValores,
                            backgroundColor: [
                                '#2563eb', // Blue-600 (Darker)
                                '#059669', // Emerald-600 (Darker)
                                '#d97706', // Amber-600 (Darker)
                                '#7c3aed', // Violet-600 (Darker)
                                '#db2777'  // Pink-600 (Darker)
                            ],
                            borderWidth: 2,
                            borderColor: '#ffffff',
                            hoverOffset: 12
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        layout: {
                            padding: 20
                        },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    usePointStyle: true,
                                    padding: 20,
                                    font: { size: 12 }
                                }
                            },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                padding: 12,
                                callbacks: {
                                    label: function(context) {
                                        let label = context.label || '';
                                        let value = context.parsed;
                                        let formatted = new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB' }).format(value);
                                        return `${label}: ${formatted}`;
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // 3. Gráfico de Barras Horizontales (Mejores Clientes)
            const ctxBar = document.getElementById('barChart');
            if (ctxBar) {
                new Chart(ctxBar, {
                    type: 'bar',
                    data: {
                        labels: barClientes,
                        datasets: [{
                            label: 'Ingresos Históricos',
                            data: barValores,
                            backgroundColor: [
                                'rgba(16, 185, 129, 0.8)', // Emerald
                                'rgba(59, 130, 246, 0.8)', // Blue
                                'rgba(245, 158, 11, 0.8)', // Amber
                                'rgba(139, 92, 246, 0.8)', // Violet
                                'rgba(236, 72, 153, 0.9)'  // Pink
                            ],
                            borderWidth: 0,
                            borderRadius: 12, // Barras con forma de píldora
                            barThickness: 24, // Barras delgadas y estilizadas
                            hoverBackgroundColor: [
                                '#059669',
                                '#2563eb',
                                '#d97706',
                                '#7c3aed',
                                '#db2777'
                            ]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        indexAxis: 'y', // Hace que las barras sean horizontales
                        layout: { padding: 10 },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                padding: 12,
                                callbacks: {
                                    label: function(context) {
                                        let value = context.parsed.x;
                                        return new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB' }).format(value);
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                grid: { color: '#e2e8f0', drawBorder: false },
                                ticks: {
                                    maxTicksLimit: 5,
                                    callback: function(value) { return 'Bs ' + value; }
                                }
                            },
                            y: {
                                grid: { display: false, drawBorder: false },
                                ticks: { font: { weight: 'bold' } }
                            }
                        }
                    }
                });
            }

            // 4. Gráfico de Área Polar (Capital en Inventario)
            const ctxPolar = document.getElementById('polarChart');
            if (ctxPolar) {
                // Ajuste visual: Interpolación lineal para que el mínimo tenga 20% de tamaño y el resto sea proporcional
                const maxPolar = Math.max(...polarValores);
                const minPolar = Math.min(...polarValores);
                
                let polarValoresVisuales = polarValores;
                if (maxPolar > minPolar) {
                    const visualMin = maxPolar * 0.20; // Tamaño mínimo garantizado
                    polarValoresVisuales = polarValores.map(v => {
                        return visualMin + ((v - minPolar) / (maxPolar - minPolar)) * (maxPolar - visualMin);
                    });
                }

                new Chart(ctxPolar, {
                    type: 'polarArea',
                    data: {
                        labels: polarCategorias,
                        datasets: [{
                            data: polarValoresVisuales, // Tamaño visual inflado para valores pequeños
                            backgroundColor: [
                                'rgba(16, 185, 129, 0.6)', // Emerald
                                'rgba(59, 130, 246, 0.6)', // Blue
                                'rgba(245, 158, 11, 0.6)', // Amber
                                'rgba(139, 92, 246, 0.6)', // Violet
                                'rgba(236, 72, 153, 0.6)'  // Pink
                            ],
                            borderColor: [
                                '#059669',
                                '#2563eb',
                                '#d97706',
                                '#7c3aed',
                                '#db2777'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        layout: { padding: 10 },
                        scales: {
                            r: {
                                ticks: { display: false },
                                grid: { color: '#e2e8f0' }
                            }
                        },
                        plugins: {
                            legend: { position: 'right', labels: { font: { size: 11 }, usePointStyle: true } },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                callbacks: {
                                    label: function(context) {
                                        // Mostrar el valor REAL de los datos, no el tamaño visual
                                        let realValue = polarValores[context.dataIndex];
                                        return new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB' }).format(realValue);
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // 5. Gráfico de Tendencia (Ticket Promedio)
            const ctxTrend = document.getElementById('trendChart');
            if (ctxTrend) {
                const gradientTrend = ctxTrend.getContext('2d').createLinearGradient(0, 0, 0, 300);
                gradientTrend.addColorStop(0, 'rgba(139, 92, 246, 0.4)'); // Violeta claro
                gradientTrend.addColorStop(1, 'rgba(139, 92, 246, 0.0)');
                
                new Chart(ctxTrend, {
                    type: 'line',
                    data: {
                        labels: trendFechas,
                        datasets: [{
                            label: 'Ticket Promedio',
                            data: trendValores,
                            borderColor: '#8b5cf6', // Violet-500
                            backgroundColor: gradientTrend,
                            borderWidth: 3,
                            fill: true,
                            tension: 0.5, // Curva suave
                            pointRadius: 4,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#8b5cf6',
                            pointBorderWidth: 2,
                            pointHoverRadius: 7
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        layout: { padding: 10 },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                callbacks: {
                                    label: function(context) {
                                        return 'Promedio: ' + new Intl.NumberFormat('es-BO', { style: 'currency', currency: 'BOB' }).format(context.raw);
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grace: '20%',
                                grid: { color: '#e2e8f0', drawBorder: false },
                                ticks: {
                                    callback: function(value) { return 'Bs ' + value; }
                                }
                            },
                            x: {
                                grid: { display: false, drawBorder: false }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
